{
    "name": "rahulalam31/laravel-abuse-ip",
    "description": "Block ip address of all spammer's around the world.",
    "keywords": [
        "framework",
        "laravel",
        "AbuseIpDB",
        "Spam protection",
        "laravel security"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "rahulalam31",
            "email": "rahulalam31@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/config": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/validation": "^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "mockery/mockery": "^1.7",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "RahulAlam31\\LaravelAbuseIp\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "RahulAlam31\\LaravelAbuseIp\\AbuseIPServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
